# TrustOS API (.env in api/ or root)
# Copy to .env and fill values. Do not commit .env.

# BACKBOARD_API_KEY=
# BACKBOARD_ASSISTANT_ID=

# S3-compatible storage (optional for local dev)
# S3_ENDPOINT_URL=
# S3_REGION=us-east-1
# S3_BUCKET=proofstack-evidence
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY_HEADER=X-API-Key

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=proofstack

# Integrations (optional)
# SLACK_WEBHOOK_URL=
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Backboard (optional)
# BACKBOARD_API_KEY=
# BACKBOARD_ASSISTANT_ID=
